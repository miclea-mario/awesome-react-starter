{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["dom", "dom.iterable", "ES2020"],
    "allowJs": true,
    "checkJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "forceConsistentCasingInFileNames": true,
    "plugins": [{ "name": "next" }],
    "paths": {
      "@api/*": ["./api/*"],
      "@auth": ["./auth/index"],
      "@auth/*": ["./auth/*"],
      "@components": ["./components/index"],
      "@components/*": ["./components/*"],
      "@components/ui": ["./components/ui/index"],
      "@components/ui/*": ["./components/ui/*"],
      "@constants": ["./constants/index"],
      "@constants/*": ["./constants/*"],
      "@css": ["./css/index"],
      "@css/*": ["./css/*"],
      "@data": ["./data/index"],
      "@data/*": ["./data/*"],
      "@examples": ["./examples/index"],
      "@examples/*": ["./examples/*"],
      "@functions": ["./functions/index"],
      "@functions/*": ["./functions/*"],
      "@hooks": ["./hooks/index"],
      "@hooks/*": ["./hooks/*"],
      "@lib": ["./lib/index"],
      "@lib/*": ["./lib/*"],
      "@models/*": ["./models/*"],
      "@site.config": ["./site.config"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    "components/Layout.jsx"
  ],
  "exclude": ["node_modules"]
}
